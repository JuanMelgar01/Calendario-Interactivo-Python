<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Calendario {{ year }}</title>
  <link rel="stylesheet" href="../assets/style.css">
</head>
<body>
  <header class="topbar">
    <div class="nav" id="monthControls">
      <button id="prevMonth" class="btn">◀</button>

      <div class="title">
        <h1 id="monthTitle"></h1>
        <div class="sub">
          <span id="yearLabel">Año {{ year }}</span>
          <label>Mes
            <select id="monthSelect">
              {% for m in range(1,13) %}
                <option value="{{ m }}">{{ m }}</option>
              {% endfor %}
            </select>
          </label>
        </div>
      </div>

      <button id="nextMonth" class="btn">▶</button>
    </div>

    <div class="nav" id="weekControls" style="display:none" aria-hidden="true">
      <button id="prevWeekTop" class="btn" type="button" aria-label="Semana anterior">◀</button>

      <div class="title">
        <h1 id="weekTitleTop"></h1>
        <div class="sub">
          <span id="yearLabelWeek">Año {{ year }}</span>
          <span>Semana</span>
        </div>
      </div>

      <button id="nextWeekTop" class="btn" type="button" aria-label="Semana siguiente">▶</button>
    </div>

    <div class="controls">
      <div class="view-toggle" role="tablist" aria-label="Vista del calendario">
        <button id="btnMonth" class="btn secondary active" role="tab" aria-selected="true" type="button">Mes</button>
        <button id="btnWeek" class="btn secondary" role="tab" aria-selected="false" type="button">Semana</button>
      </div>

      <label>Filtrar categoría:
        <select id="categoryFilter">
          <option value="__all__">Todas</option>
          {% for c in categories %}
            <option value="{{ c|e }}">{{ c|e }}</option>
          {% endfor %}
        </select>
      </label>
      <button id="printBtn" class="btn secondary">Imprimir</button>
    </div>
  </header>

  <main class="layout">
    <section class="calendar">
      <div class="weekday">
        <div>Lun</div><div>Mar</div><div>Mié</div><div>Jue</div><div>Vie</div><div>Sáb</div><div>Dom</div>
      </div>

      <div id="monthView">
        <div id="yearContainer">
          {% for mctx in months %}
            <div class="grid month-grid"
                 data-month="{{ mctx.month }}"
                 style="display:none"
                 aria-hidden="true">
              {% for week in mctx.weeks %}
                {% for day in week %}
                  <div class="cell {% if not day.in_month %}muted{% endif %}" data-date="{{ day.date }}">
                    <div class="cell-top">
                      <span class="daynum">{{ day.day }}</span>
                    </div>
                    <div class="events">
                      {% for ev in day.events %}
                        <button class="event"
                                data-event='{{ ev | tojson }}'
                                data-category="{{ ev.category|e }}"
                                title="{{ ev.title|e }} ({{ ev.category|e }})">
                          <span class="dot" data-category="{{ ev.category|e }}"></span>
                          <span class="ev-title">{{ ev.title|e }}</span>
                        </button>
                      {% endfor %}
                    </div>
                  </div>
                {% endfor %}
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </div>

      <div id="weekView" style="display:none" aria-hidden="true">
        <div id="weekGrid" class="week-grid" role="grid" aria-label="Calendario semanal"></div>
      </div>
    </section>

    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h2>Detalles</h2>
        <button id="closeSidebar" class="btn small">✕</button>
      </div>

      <div class="sidebar-content" id="sidebarContent">
        <p class="hint">Haz clic en un evento para ver más información.</p>
      </div>
    </aside>
  </main>

  <div id="tooltip" class="tooltip" role="tooltip" aria-hidden="true">
    <div class="tooltip-card">
      <div class="tooltip-top">
        <p class="tooltip-title" id="ttTitle"></p>
        <span class="tooltip-badge" id="ttBadge"></span>
      </div>
      <div class="tooltip-body">
        <p class="tooltip-when" id="ttWhen"></p>
        <p class="tooltip-desc" id="ttDesc"></p>
      </div>
    </div>
  </div>

<script id="events-data" type="application/json">
  {{ all_events | tojson }}
</script>
<script>
  const monthNames = ["enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre"];
  const monthSelect = document.getElementById("monthSelect");
  const monthTitle = document.getElementById("monthTitle");
  const grids = Array.from(document.querySelectorAll(".month-grid"));

  const monthView = document.getElementById("monthView");
  const weekView = document.getElementById("weekView");
  const weekGrid = document.getElementById("weekGrid");

  const monthControls = document.getElementById("monthControls");
  const weekControls = document.getElementById("weekControls");
  const prevWeekTop = document.getElementById("prevWeekTop");
  const nextWeekTop = document.getElementById("nextWeekTop");
  const weekTitleTop = document.getElementById("weekTitleTop");

  const btnMonth = document.getElementById("btnMonth");
  const btnWeek = document.getElementById("btnWeek");

  const tooltip = document.getElementById("tooltip");
  const ttTitle = document.getElementById("ttTitle");
  const ttBadge = document.getElementById("ttBadge");
  const ttWhen  = document.getElementById("ttWhen");
  const ttDesc  = document.getElementById("ttDesc");
  let tooltipVisible = false;

  function fmtRange(ev){
    const s = new Date(ev.start);
    const e = ev.end ? new Date(ev.end) : null;
    const optsDate = { year:"numeric", month:"2-digit", day:"2-digit" };
    const optsTime = { hour:"2-digit", minute:"2-digit" };

    const sDate = s.toLocaleDateString("es-ES", optsDate);
    const sTime = s.toLocaleTimeString("es-ES", optsTime);

    if(!e) return `${sDate} ${sTime}`;

    const eDate = e.toLocaleDateString("es-ES", optsDate);
    const eTime = e.toLocaleTimeString("es-ES", optsTime);

    if(sDate === eDate) return `${sDate} ${sTime} - ${eTime}`;
    return `${sDate} ${sTime} → ${eDate} ${eTime}`;
  }

  function escapeHtml(str){
    return String(str ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#039;");
  }

  function showTooltip(evData, x, y){
    ttTitle.textContent = evData.title || "";
    ttBadge.textContent = evData.category || "";
    ttBadge.setAttribute("data-category", evData.category || "");
    ttWhen.innerHTML = `<strong>Cuándo:</strong> ${fmtRange(evData)}`;
    ttDesc.textContent = evData.description || "";

    tooltip.classList.add("show");
    tooltip.setAttribute("aria-hidden", "false");
    tooltipVisible = true;

    positionTooltip(x, y);
  }

  function hideTooltip(){
    tooltip.classList.remove("show");
    tooltip.setAttribute("aria-hidden", "true");
    tooltipVisible = false;
  }

  function positionTooltip(x, y){
    const pad = 14;
    const offsetX = 14;
    const offsetY = 16;

    tooltip.style.left = "0px";
    tooltip.style.top = "0px";
    tooltip.style.right = "auto";

    const rect = tooltip.getBoundingClientRect();
    const vw = window.innerWidth;
    const vh = window.innerHeight;

    let left = x + offsetX;
    let top  = y + offsetY;

    if(left + rect.width + pad > vw){
      left = Math.max(pad, x - rect.width - offsetX);
    }
    if(top + rect.height + pad > vh){
      top = Math.max(pad, y - rect.height - offsetY);
    }

    tooltip.style.left = `${left}px`;
    tooltip.style.top  = `${top}px`;
  }

  const sidebar = document.getElementById("sidebar");
  const sidebarContent = document.getElementById("sidebarContent");
  const closeSidebarBtn = document.getElementById("closeSidebar");
  if(closeSidebarBtn){
    closeSidebarBtn.addEventListener("click", () => sidebar.classList.remove("open"));
  }

  function openEvent(ev){
    sidebarContent.innerHTML = `
      <div class="detail">
        <div class="badge" data-category="${escapeHtml(ev.category)}">${escapeHtml(ev.category)}</div>
        <h3>${escapeHtml(ev.title)}</h3>
        <p class="when"><strong>Cuándo:</strong> ${fmtRange(ev)}</p>
        <p class="desc">${escapeHtml(ev.description || "")}</p>
      </div>
    `;
    sidebar.classList.add("open");
  }

  const state = {
    view: "month",
    weekCursor: new Date()
  };

  const categoryFilter = document.getElementById("categoryFilter");

  function getActiveContainer(){
    if(state.view === "week") return weekGrid;
    return grids.find(g => g.style.display !== "none");
  }

  function applyFilter(){
    const v = categoryFilter.value;
    const container = getActiveContainer();
    if(!container) return;

    container.querySelectorAll(".event").forEach(btn => {
      const c = btn.dataset.category;
      const show = (v === "__all__" || c === v);
      btn.style.display = show ? "flex" : "none";
    });
  }

  categoryFilter.addEventListener("change", applyFilter);

  function bindActiveEvents(){
    const container = getActiveContainer();
    if(!container) return;

    container.querySelectorAll(".event").forEach(btn => {
      const evData = JSON.parse(btn.dataset.event);

      btn.onclick = () => openEvent(evData);

      btn.onmouseenter = (e) => showTooltip(evData, e.clientX, e.clientY);
      btn.onmousemove  = (e) => { if(tooltipVisible) positionTooltip(e.clientX, e.clientY); };
      btn.onmouseleave = hideTooltip;

      btn.onfocus = () => {
        const r = btn.getBoundingClientRect();
        showTooltip(evData, r.left + r.width/2, r.top);
      };
      btn.onblur = hideTooltip;
    });
  }

  function showMonth(m){
    grids.forEach(g => {
      const gm = parseInt(g.dataset.month, 10);
      const active = (gm === m);
      g.style.display = active ? "grid" : "none";
      g.setAttribute("aria-hidden", active ? "false" : "true");
    });

    monthSelect.value = String(m);
    monthTitle.textContent = `${monthNames[m-1]} {{ year }}`;
    applyFilter();
    bindActiveEvents();
  }

  function syncMonthToCursor(){
    const m = state.weekCursor.getMonth() + 1;
    showMonth(m);
  }

  function shiftMonth(delta){
    let m = parseInt(monthSelect.value, 10);
    m += delta;
    if(m === 0) m = 12;
    if(m === 13) m = 1;
    showMonth(m);
  }

  document.getElementById("prevMonth").addEventListener("click", () => {
    if(state.view === "month") shiftMonth(-1);
  });
  document.getElementById("nextMonth").addEventListener("click", () => {
    if(state.view === "month") shiftMonth(1);
  });
  monthSelect.addEventListener("change", () => {
    if(state.view === "month") showMonth(parseInt(monthSelect.value, 10));
  });

  document.getElementById("printBtn").addEventListener("click", () => window.print());
  window.addEventListener("scroll", () => { if(tooltipVisible) hideTooltip(); }, { passive: true });
  window.addEventListener("resize", () => { if(tooltipVisible) hideTooltip(); }, { passive: true });
  document.addEventListener("keydown", (e) => { if(e.key === "Escape") hideTooltip(); });

  const eventsDataEl = document.getElementById("events-data");
  const ALL_EVENTS = eventsDataEl ? JSON.parse(eventsDataEl.textContent) : [];

  function toISODate(d){
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth()+1).padStart(2,"0");
    const dd = String(d.getDate()).padStart(2,"0");
    return `${yyyy}-${mm}-${dd}`;
  }

  function startOfWeek(date){
    const d = new Date(date);
    const day = d.getDay();
    const diff = (day === 0 ? -6 : 1 - day);
    d.setDate(d.getDate() + diff);
    d.setHours(0,0,0,0);
    return d;
  }

  function addDays(date, n){
    const d = new Date(date);
    d.setDate(d.getDate() + n);
    return d;
  }

  function eventCoversDay(ev, isoDay){
    const s = (ev.start || "").slice(0,10);
    const e = (ev.end ? ev.end.slice(0,10) : s);
    return s <= isoDay && isoDay <= e;
  }

  function renderWeek(){
    const ws = startOfWeek(state.weekCursor);
    const we = addDays(ws, 6);

    weekTitleTop.textContent = `${ws.toLocaleDateString("es-ES")} — ${we.toLocaleDateString("es-ES")}`;

    weekGrid.innerHTML = "";
    for(let i=0; i<7; i++){
      const d = addDays(ws, i);
      const iso = toISODate(d);

      const cell = document.createElement("div");
      cell.className = "week-cell";
      cell.setAttribute("role", "gridcell");
      cell.dataset.date = iso;

      const head = document.createElement("div");
      head.className = "week-cell-top";
      head.innerHTML = `<span class="daynum">${d.getDate()}</span>`;
      cell.appendChild(head);

      const eventsBox = document.createElement("div");
      eventsBox.className = "events";

      const todays = ALL_EVENTS.filter(ev => eventCoversDay(ev, iso));
      todays.forEach(ev => {
        const btn = document.createElement("button");
        btn.className = "event";
        btn.dataset.event = JSON.stringify(ev);
        btn.dataset.category = ev.category || "";
        btn.title = `${ev.title || ""} (${ev.category || ""})`;

        btn.innerHTML = `
          <span class="dot" data-category="${escapeHtml(ev.category || "")}"></span>
          <span class="ev-title">${escapeHtml(ev.title || "")}</span>
        `;
        eventsBox.appendChild(btn);
      });

      cell.appendChild(eventsBox);
      weekGrid.appendChild(cell);
    }

    applyFilter();
    bindActiveEvents();
  }

  function setView(view){
    state.view = view;
    const isMonth = view === "month";

    monthControls.style.display = isMonth ? "flex" : "none";
    monthControls.setAttribute("aria-hidden", isMonth ? "false" : "true");

    weekControls.style.display = isMonth ? "none" : "flex";
    weekControls.setAttribute("aria-hidden", isMonth ? "true" : "false");

    monthView.style.display = isMonth ? "" : "none";
    monthView.setAttribute("aria-hidden", isMonth ? "false" : "true");

    weekView.style.display = isMonth ? "none" : "";
    weekView.setAttribute("aria-hidden", isMonth ? "true" : "false");

    btnMonth.classList.toggle("active", isMonth);
    btnMonth.setAttribute("aria-selected", isMonth ? "true" : "false");
    btnWeek.classList.toggle("active", !isMonth);
    btnWeek.setAttribute("aria-selected", !isMonth ? "true" : "false");

    if(!isMonth){
      renderWeek();
    }else{
      syncMonthToCursor();
      applyFilter();
      bindActiveEvents();
    }
  }

  btnMonth.addEventListener("click", () => setView("month"));
  btnWeek.addEventListener("click", () => {
    const y = {{ year }};
    const m = parseInt(monthSelect.value, 10);
    state.weekCursor = new Date(y, m - 1, 1);
    syncMonthToCursor();
    setView("week");
  });

  prevWeekTop.addEventListener("click", () => {
    if(state.view !== "week") return;
    state.weekCursor = addDays(state.weekCursor, -7);
    syncMonthToCursor();
    renderWeek();
  });

  nextWeekTop.addEventListener("click", () => {
    if(state.view !== "week") return;
    state.weekCursor = addDays(state.weekCursor, 7);
    syncMonthToCursor();
    renderWeek();
  });

  (function init(){
    const now = new Date();
    let startMonth = 1;
    const y = {{ year }};
    if(now.getFullYear() === y) startMonth = now.getMonth() + 1;
    showMonth(startMonth);
    setView("month");
  })();
</script>

</body>
</html>
